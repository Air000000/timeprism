{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TimePrism",
  "version": "0.1.0",
  "identifier": "com.air.timeprism",
  "build": {
  "beforeDevCommand": "pnpm vite",
  "devUrl": "http://localhost:1420",
  "beforeBuildCommand": "pnpm build",
  "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TimePrism",
        "width": 888,
        "height": 900,
        "minWidth": 888,
        "minHeight": 900
      },
      {
        "label": "pet",
        "title": "TimePrism Pet",
        "url": "pet.html",
        "width": 220,
        "height": 232,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false
      },
      {
        "label": "pet-panel",
        "title": "TimePrism Panel",
        "url": "pet-panel.html",
        "width": 186,
        "height": 128,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
